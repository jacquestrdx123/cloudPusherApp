# API host is hardcoded to https://cloudpusher-backend.on-forge.com (see src/config/env.ts).
# During `npm run dev`, requests go through the Vite proxy to avoid CORS.

# Firebase web config lives in firebase.json (defaults).
# Override any value here, and set the VAPID key for web push:
VITE_FIREBASE_VAPID_KEY=
