# Default API host: https://cloudpusher-backend.on-forge.com (see src/config/env.ts).
# Native iOS/Android always use that host (or VITE_API_BASE_URL if set).
# Browser `npm run dev` uses the Vite proxy → same Forge host (avoids CORS).
#
# Optional override (no trailing slash):
# VITE_API_BASE_URL=https://cloudpusher-backend.on-forge.com

# Firebase web config + public VAPID key live in firebase.json (defaults).
# Optional overrides:
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_VAPID_KEY=
